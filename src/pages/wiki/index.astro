---
import { BaseLayout } from "@/layouts/BaseLayout"
import { getWikiPages, getWikiSections, toWikiHref } from "@/lib/wiki"
import WikiSidebar from "@/components/Elements/WikiSidebar/WikiSidebar.astro"
import WikiPageListPanel from "@/components/Elements/WikiSidebar/WikiPageListPanel.astro"

const pages = await getWikiPages()
const sections = getWikiSections(pages)
---

<BaseLayout
  title="Wiki"
  description="RICORA Programming Team Wiki"
  og={{
    url: new URL("/wiki/", Astro.site),
  }}
>
  <main class="mx-auto my-8 flex w-full max-w-[1600px] flex-1 gap-6">
    <aside class="hidden w-80 shrink-0 xl:block">
      <div class="sticky top-20">
        <WikiSidebar sections={sections} variant="panel" state={{ kind: "none" }} />
      </div>
    </aside>

    <section class="w-full">
      <WikiPageListPanel sections={sections} />

      <header class="mb-8">
        <h1 class="text-4xl font-bold">Wiki</h1>
        <p class="mt-3 text-fg-muted">RICORA Programming Teamの活動や開発で役立つ知見をまとめたドキュメント集です。</p>
      </header>

      <div class="grid gap-6 md:grid-cols-2">
        {
          sections.map((section) => (
            <section class="rounded-lg border bg-bg-default p-4">
              <h2 class="text-xl font-bold text-fg-default">
                {section.slug ? (
                  <a href={toWikiHref(section.slug)} class="text-fg-default transition hover:text-fg-default">
                    {section.title}
                  </a>
                ) : (
                  <span>{section.title}</span>
                )}
              </h2>
              <ul class="mt-3 list-disc space-y-2 pl-5">
                {section.pages.map((page) => (
                  <li>
                    <a href={toWikiHref(page.slug)} class="text-fg-muted transition hover:text-fg-default">
                      {page.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
